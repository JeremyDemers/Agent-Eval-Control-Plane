{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DiscoverTextModels",
      "Effect": "Allow",
      "Action": "bedrock:ListFoundationModels",
      "Resource": "*"
    },
    {
      "Sid": "InvokeApprovedFoundationModel",
      "Effect": "Allow",
      "Action": "bedrock:InvokeModel",
      "Resource": "arn:aws:bedrock:us-east-1::foundation-model/replace-with-approved-model-id"
    }
  ]
}
